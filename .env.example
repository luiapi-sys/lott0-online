# Local env (loaded by Prisma CLI via prisma.config.ts). NOT committed.
NODE_ENV=development

# Database — local docker-compose exposes postgres on 5455 (5432 taken by another project)
DATABASE_URL=postgresql://lott0:lott0@localhost:5455/lott0?schema=public

# JWT (set real secrets before prod)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=2592000

BCRYPT_ROUNDS=12

# Redis — local compose maps 6380 -> 6379
REDIS_HOST=localhost
REDIS_PORT=6380

# Worker loop intervals (seconds)
WORKER_AUDIT_INTERVAL=270
WORKER_OPTIMIZE_INTERVAL=3600
WORKER_CONSOLIDATE_INTERVAL=86400
